# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=testdb
POSTGRES_USER=readonly_user
POSTGRES_PASSWORD=your_password_here

# Write Database (for execution)
POSTGRES_WRITE_HOST=localhost
POSTGRES_WRITE_PORT=5432
POSTGRES_WRITE_DB=testdb
POSTGRES_WRITE_USER=dba_user
POSTGRES_WRITE_PASSWORD=your_write_password_here

# Vector Store Database
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=knowledge_base
VECTOR_DB_USER=vector_user
VECTOR_DB_PASSWORD=your_vector_password_here

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
DASHSCOPE_API_KEY=your-qwen-key-here

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat  # or deepseek-coder

# LLM Provider Selection (openai|anthropic|qwen|deepseek)
PRIMARY_LLM_PROVIDER=openai
SECONDARY_LLM_PROVIDER=deepseek

# MCP Server Configuration
MCP_READ_SERVER_PORT=8001
MCP_WRITE_SERVER_PORT=8002

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Security
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Configuration
MAX_WORKFLOW_TIMEOUT_SECONDS=1800
HEALTH_CHECK_DURATION_SECONDS=300
SNAPSHOT_RETENTION_DAYS=7

# Query Safety Limits
MAX_QUERY_TIMEOUT_SECONDS=30
MAX_RESULT_ROWS=100
