{
  "mcp_tools": {
    "read_probe": {
      "enabled": true,
      "tools": [
        {
          "name": "get_db_schema",
          "description": "Get database schema for specified tables",
          "permission_level": "read",
          "rate_limit": 100
        },
        {
          "name": "get_pg_stat_statements",
          "description": "Get slow query statistics from pg_stat_statements",
          "permission_level": "read",
          "rate_limit": 50
        },
        {
          "name": "get_blocking_locks",
          "description": "Get current blocking locks and sessions",
          "permission_level": "read",
          "rate_limit": 100
        },
        {
          "name": "explain_query",
          "description": "Get execution plan for a query (with automatic rollback)",
          "permission_level": "read",
          "rate_limit": 50
        },
        {
          "name": "execute_safe_select",
          "description": "Execute read-only SELECT query with safety limits",
          "permission_level": "read",
          "rate_limit": 30
        }
      ]
    },
    "write_execute": {
      "enabled": true,
      "tools": [
        {
          "name": "create_storage_snapshot",
          "description": "Create volume snapshot before executing changes",
          "permission_level": "write",
          "rate_limit": 10,
          "requires_approval": true
        },
        {
          "name": "execute_tuning_script",
          "description": "Execute DBA-approved tuning script",
          "permission_level": "write",
          "rate_limit": 5,
          "requires_approval": true,
          "requires_snapshot": true
        },
        {
          "name": "rollback_to_snapshot",
          "description": "Emergency rollback to previous snapshot",
          "permission_level": "write",
          "rate_limit": 10,
          "requires_approval": true
        }
      ]
    }
  },
  "safety_policies": {
    "max_query_timeout_seconds": 30,
    "max_result_rows": 100,
    "force_readonly_mode": true,
    "block_dangerous_keywords": true,
    "require_snapshot_before_ddl": true,
    "auto_rollback_on_degradation": true
  },
  "monitoring": {
    "log_all_queries": true,
    "log_query_plans": true,
    "track_execution_time": true,
    "alert_on_slow_queries": true,
    "slow_query_threshold_ms": 1000
  }
}
